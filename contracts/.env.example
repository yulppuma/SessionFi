# SessionFi Contracts Environment Variables
# Copy this file to .env and fill in your values

# Private key for contract deployment (your wallet's private key)
# Get from MetaMask: Account Details > Export Private Key
PRIVATE_KEY=0x...

# RPC URL for Sepolia Testnet
# Get from https://infura.io (create a project and get the key)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# RPC URL for Ethereum Mainnet (optional, for future mainnet deployment)
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Etherscan API Key for contract verification
# Get from https://etherscan.io/apis (sign up and create API key)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
