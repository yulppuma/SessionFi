# SessionFi Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# WalletConnect Project ID
# Get from https://cloud.walletconnect.com
VITE_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Infura API Key
# Get from https://infura.io
VITE_INFURA_KEY=your_infura_api_key_here

# Deployed SessionFi Contract Address (Sepolia Testnet)
# Get from contract deployment output
VITE_SESSION_FI_CONTRACT=0x...

# Optional: SessionManager Contract Address
VITE_SESSION_MANAGER_CONTRACT=0x...

# Optional: USDC Token Address on Sepolia
VITE_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
